# ─── Database ────────────────────────────────────────────────────────────────
# Railway PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/starwatch"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"

# URL of your app (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-railway-app.up.railway.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── SendGrid ─────────────────────────────────────────────────────────────────
# Get at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
# The "from" address for notification emails (must be verified in SendGrid)
SENDGRID_FROM_EMAIL="starwatch@yourdomain.com"
SENDGRID_FROM_NAME="StarWatch"

# ─── NASA API ─────────────────────────────────────────────────────────────────
# Free key at: https://api.nasa.gov/
NASA_API_KEY="your-nasa-api-key"

# ─── AstronomyAPI ─────────────────────────────────────────────────────────────
# Free account at: https://astronomyapi.com/
ASTRONOMY_API_APP_ID="your-astronomy-api-app-id"
ASTRONOMY_API_APP_SECRET="your-astronomy-api-app-secret"

# ─── Cron Security ────────────────────────────────────────────────────────────
# Secret used to protect /api/cron/* routes from unauthorized calls
# Generate: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
